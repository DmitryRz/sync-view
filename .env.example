# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=db

# Common
DOMAIN_NAME=bintry.ru
PROTOCOL=https://
APP_PROFILE=prod

# Frontend
VITE_KEYCLOAK_URL=${PROTOCOL}${DOMAIN_NAME}/auth
VITE_KEYCLOAK_CLIENT_ID=frontend-client
VITE_KEYCLOAK_REALM=syncview

# Keycloak 
KC_DB_USER=postgres
KC_DB_PASSWORD=password
KC_DB_NAME=db
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_HOSTNAME_URL=${PROTOCOL}${DOMAIN_NAME}/auth
KEYCLOAK_ISSUER_URI=${PROTOCOL}${DOMAIN_NAME}/auth/realms/syncview
KEYCLOAK_JWK_SET_URI=${PROTOCOL}${DOMAIN_NAME}/auth/realms/syncview/protocol/openid-connect/certs

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET_NAME=uploads
MINIO_INTERNAL_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=${PROTOCOL}${DOMAIN_NAME}/storage
BACKEND_ACCESS_KEY=random-access-key
BACKEND_SECRET_KEY=random-secret-key
